{
  "name": "@spbu/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run build --workspace @spbu/contracts && npm run build:self",
    "build:self": "npm run clean && tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/**/*.test.js",
    "test:coverage": "npm run build && node --test --experimental-test-coverage --test-coverage-lines=90 --test-coverage-functions=90 --test-coverage-branches=90 dist/**/*.test.js",
    "start": "node dist/server.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:verify": "tsx src/db/verifySchema.ts",
    "db:verify-account-assignment": "tsx src/db/verifyAccountAssignment.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:import-historical": "tsx src/db/importHistoricalStock.ts",
    "db:stage-historical-source": "tsx src/db/stageHistoricalSourceRows.ts",
    "auth:bootstrap-admin": "tsx src/db/bootstrapAdmin.ts"
  },
  "dependencies": {
    "@spbu/contracts": "1.0.0",
    "@types/node": "24.13.3",
    "@types/pg": "8.20.0",
    "@vercel/functions": "3.7.5",
    "pg": "8.22.0",
    "typescript": "7.0.2"
  },
  "devDependencies": {
    "tsx": "4.23.1"
  }
}
