# API
NODE_ENV=development
ALLOW_LOCAL_SEED=true
API_HOST=0.0.0.0
API_PORT=8787
WEB_ORIGIN=http://localhost:5173
ALLOWED_WEB_ORIGINS=http://localhost:5173
ALLOW_PRIVATE_NETWORK_ORIGINS=true
PRIVATE_NETWORK_WEB_PORTS=5173,4173
REQUIRE_CLIENT_PROVENANCE=false
NATIVE_CLIENT_KEY_HASHES={}
TRUST_PROXY=false
DATABASE_URL=postgres://spbu:spbu-local-only@localhost:5432/spbu_ops
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT_MS=5000
DB_QUERY_TIMEOUT_MS=20000
DB_STATEMENT_TIMEOUT_MS=15000
REGISTRATION_CODE_SECRET=replace-this-local-registration-secret
SESSION_TTL_HOURS=12
SESSION_TOUCH_INTERVAL_MINUTES=5
SESSION_COOKIE_NAME=pli_session
SESSION_COOKIE_SECURE=false
BOOTSTRAP_ADMIN_EMAIL=yudhizz14@gmail.com
BOOTSTRAP_ADMIN_PASSWORD=ChangeMeLocal123!
BOOTSTRAP_ADMIN_NAME=Mr.Yudhistira

# Object storage (SeaweedFS defaults from docker-compose.yml)
S3_ENDPOINT=http://localhost:8333
S3_INTERNAL_ENDPOINT=http://localhost:8333
S3_REGION=us-east-1
S3_BUCKET=pli-documents
S3_ACCESS_KEY=pli-local-access
S3_SECRET_KEY=pli-local-secret-change-me
S3_FORCE_PATH_STYLE=true
S3_PRESIGN_TTL_SECONDS=900
S3_REQUEST_TIMEOUT_MS=7500
S3_ALLOWED_ORIGINS=*

# Web
VITE_API_BASE_URL=http://localhost:8787/api/v1
VITE_USE_MOCKS=true
