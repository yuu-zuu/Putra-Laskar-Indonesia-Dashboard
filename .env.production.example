# Salin nilainya ke Vercel Project Settings > Environment Variables; jangan commit secret asli.
NODE_ENV=production
WEB_ORIGIN=https://dashboard.example.com
ALLOWED_WEB_ORIGINS=https://dashboard.example.com
ALLOW_PRIVATE_NETWORK_ORIGINS=false
PRIVATE_NETWORK_WEB_PORTS=5173,4173
REQUIRE_CLIENT_PROVENANCE=true
NATIVE_CLIENT_KEY_HASHES={}
TRUST_PROXY=true

# Gunakan endpoint PostgreSQL pooled pada region yang sama dengan Vercel Function.
DATABASE_URL=postgres://APP_USER:REPLACE_ME@POOLED_HOST:5432/APP_DATABASE?sslmode=require
DB_POOL_MAX=2
DB_CONNECTION_TIMEOUT_MS=5000
DB_QUERY_TIMEOUT_MS=20000
DB_STATEMENT_TIMEOUT_MS=15000

REGISTRATION_CODE_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS
SESSION_TTL_HOURS=12
SESSION_TOUCH_INTERVAL_MINUTES=5
SESSION_COOKIE_NAME=__Host-pli_session
SESSION_COOKIE_SECURE=true
ALLOW_LOCAL_SEED=false

# Kosongkan bootstrap setelah akun admin awal selesai dibuat dari workstation tepercaya.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=Mr.Yudhistira

S3_ENDPOINT=https://objects.example.com
S3_INTERNAL_ENDPOINT=https://objects.example.com
S3_REGION=ap-southeast-1
S3_BUCKET=pli-documents-production
S3_ACCESS_KEY=REPLACE_ME
S3_SECRET_KEY=REPLACE_ME
S3_FORCE_PATH_STYLE=true
S3_PRESIGN_TTL_SECONDS=900
S3_REQUEST_TIMEOUT_MS=7500

VITE_API_BASE_URL=/api/v1
VITE_USE_MOCKS=false
